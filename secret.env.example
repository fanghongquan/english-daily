# ════════════════════════════════════════════════════════════════
#  使用方法：
#  1) 把本文件复制一份，改名为  secret.env
#  2) 把下面等号右边换成你自己的值（等号两边不要留空格）
#  3) 保存即可，脚本会自动读取。secret.env 不会被上传到 GitHub。
# ════════════════════════════════════════════════════════════════

# ── 腾讯云语音合成（自然发音，必填这两项）──────────────────────
TENCENT_SECRET_ID=这里粘贴你的SecretId
TENCENT_SECRET_KEY=这里粘贴你的SecretKey
# 音色：101051=精品英文女声  101050=精品英文男声
TTS_VOICE=101051

# ── 飞书群机器人（推送用）──────────────────────────────────────
FEISHU_WEBHOOK=这里粘贴你的飞书webhook地址
# 机器人若开了"签名校验"才填密钥；没开就留空
FEISHU_SECRET=

# ── 网页根地址（部署到 GitHub Pages 后再填；本地测试可留空）──────
SITE_BASE_URL=

# ── 文章自动生成（可选，二选一；只本地测试可都留空）──────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
